@page "/reports"

@using FoodJournal.Application.DTOs
@using FoodJournal.Application.Enums
@inject IReportService ReportService
@inject ICurrentUserService CurrentUserService

<PageTitle>Reports</PageTitle>

<section class="flex flex-col gap-6 p-6">

    @* Summary Cards *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">

        @* Calories Today *@
        <div class="p-4 rounded-lg bg-stone-950 ring-1 shadow-xs ring-white/10">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-cyan-400">local_fire_department</span>
                <span class="text-stone-400 text-sm">Today's Calories</span>
            </div>
            <div class="text-2xl font-bold text-stone-50">@SummaryCards?.CaloriesToday.ToString("N0")</div>
            <div class="text-stone-500 text-sm">kcal</div>
        </div>

        @* Calories This Week *@
        <div class="p-4 rounded-lg bg-stone-950 ring-1 shadow-xs ring-white/10">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-emerald-400">date_range</span>
                <span class="text-stone-400 text-sm">This Week</span>
            </div>
            <div class="text-2xl font-bold text-stone-50">@SummaryCards?.CaloriesThisWeek.ToString("N0")</div>
            <div class="text-stone-500 text-sm">kcal</div>
        </div>

        @* Calories This Month *@
        <div class="p-4 rounded-lg bg-stone-950 ring-1 shadow-xs ring-white/10">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-blue-400">calendar_month</span>
                <span class="text-stone-400 text-sm">This Month</span>
            </div>
            <div class="text-2xl font-bold text-stone-50">@SummaryCards?.CaloriesThisMonth.ToString("N0")</div>
            <div class="text-stone-500 text-sm">kcal</div>
        </div>

        @* Average Daily Calories *@
        <div class="p-4 rounded-lg bg-stone-950 ring-1 shadow-xs ring-white/10">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-purple-400">trending_up</span>
                <span class="text-stone-400 text-sm">Daily Average</span>
            </div>
            <div class="text-2xl font-bold text-stone-50">@SummaryCards?.AverageDailyCalories.ToString("N0")</div>
            <div class="text-stone-500 text-sm">kcal/day</div>
        </div>

        @* Most Frequent Food Month *@
        <div class="p-4 rounded-lg bg-stone-950 ring-1 shadow-xs ring-white/10 lg:col-span-2">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-yellow-400">star</span>
                <span class="text-stone-400 text-sm">Most Frequent This Month</span>
            </div>
            @if(SummaryCards?.MostFrequentFoodThisMonth is not null)
            {
                var food = SummaryCards.MostFrequentFoodThisMonth.Food;

                <div class="flex items-center gap-4">
                    <img src="@food.Base64Image" alt="@food.Name" class="w-12 h-12 object-cover rounded" />
                    <div>
                        <div class="text-xl font-bold text-stone-50">@food.Name</div>
                        <div class="text-stone-500 text-sm">
                            Logged @(SummaryCards.MostFrequentFoodThisMonth.OccurrenceCount) times
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-xl font-bold text-stone-50">No data</div>
            }
        </div>

        @* Most Frequent Food All Time *@
        <div class="p-4 rounded-lg bg-stone-950 ring-1 shadow-xs ring-white/10 lg:col-span-2">
            <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-red-400">star</span>
                <span class="text-stone-400 text-sm">Most Frequent All Time</span>
            </div>
            @if (SummaryCards?.MostFrequentFoodAllTime is not null)
            {
                var food = SummaryCards.MostFrequentFoodAllTime.Food;

                <div class="flex items-center gap-4">
                    <img src="@food.Base64Image" alt="@food.Name" class="w-12 h-12 object-cover rounded" />
                    <div>
                        <div class="text-xl font-bold text-stone-50">@food.Name</div>
                        <div class="text-stone-500 text-sm">
                            Logged @(SummaryCards.MostFrequentFoodAllTime.OccurrenceCount) times
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="text-xl font-bold text-stone-50">No data</div>
            }
        </div>
    </div>

    @* Food Frequency Report Section *@
    <div class="rounded-lg bg-stone-950 ring-1 shadow-xs ring-white/10 p-6">
        <h2 class="text-xl font-bold text-stone-50 mb-4">Food Frequency Report</h2>

        @* Filters *@
        <div class="flex flex-wrap gap-4 mb-4">

            @* Period Selection *@
            <div>
                <label class="block text-stone-400 text-sm mb-1">Period</label>
                <InputSelect @bind-Value="SelectedPeriod"
                             class="px-3 py-2 rounded-lg bg-stone-900 text-stone-50 border border-stone-700">
                    <option value="@ReportPeriod.Week">This Week</option>
                    <option value="@ReportPeriod.Month">This Month</option>
                    <option value="@ReportPeriod.Year">This Year</option>
                    <option value="@ReportPeriod.AllTime">All Time</option>
                    <option value="@ReportPeriod.Custom">Custom Range</option>
                </InputSelect>
            </div>


            @* Food Selection Dropdown *@
            <div>
                <label class="block text-stone-400 text-sm mb-1">Food</label>
                <InputSelect @bind-Value="SelectedFoodId"
                             class="px-3 py-2 rounded-lg bg-stone-900 text-stone-50 border border-stone-700 min-w-[200px]">
                    <option value="">All Foods</option>
                    @foreach (var food in AvailableFoods)
                    {
                        <option value="@food.FoodId">@food.FoodName</option>
                    }
                </InputSelect>
            </div>


            @* Custom Date Range (shown when Custom is selected) *@
            @if (SelectedPeriod == ReportPeriod.Custom)
            {
                <div>
                    <label class="block text-stone-400 text-sm mb-1">Start Date</label>
                    <InputDate @bind-Value="CustomStartDate"
                               class="px-3 py-2 rounded-lg bg-stone-900 text-stone-50 border border-stone-700" />
                </div>
                <div>
                    <label class="block text-stone-400 text-sm mb-1">End Date</label>
                    <InputDate @bind-Value="CustomEndDate"
                               class="px-3 py-2 rounded-lg bg-stone-900 text-stone-50 border border-stone-700" />
                </div>
            }


            @* Action Buttons *@
            <div class="flex items-end gap-2">
                <button type="button"
                        class="px-6 py-2 rounded-lg bg-cyan-400 text-stone-900 font-semibold hover:bg-cyan-500 transition-colors"
                        @onclick="GenerateReportAsync">
                    Generate Report
                </button>
                <button type="button"
                        class="px-6 py-2 rounded-lg bg-stone-700 text-stone-50 hover:bg-stone-600 transition-colors"
                        @onclick="ClearFilters">
                    Clear
                </button>
            </div>

        </div>

        @* Results *@
        @if (FrequencyReport != null)
        {
            <div class="text-stone-400 text-sm mb-4">
                Showing @FrequencyReport.Foods.Count foods
                (@DisplayReportDateRange)
            </div>

            @if (FrequencyReport.Foods.Count == 0)
            {
                <div class="text-center py-8">
                    <span class="material-symbols-outlined text-4xl text-stone-500 mb-2">search_off</span>
                    <p class="text-stone-400">No food data found for the selected period</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left text-stone-50">
                        <thead class="text-xs text-stone-400 uppercase bg-stone-900">
                            <tr>
                                <th class="px-4 py-3">Food Name</th>
                                <th class="px-4 py-3">Times Eaten</th>
                                <th class="px-4 py-3">Total Calories</th>
                                <th class="px-4 py-3">Total Carbs</th>
                                <th class="px-4 py-3">Total Protein</th>
                                <th class="px-4 py-3">Total Fat</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var food in FrequencyReport.Foods)
                            {
                                <tr class="border-b border-stone-800 hover:bg-stone-900/50">
                                    <td class="px-4 py-3 font-medium text-stone-50">@food.FoodName</td>
                                    <td class="px-4 py-3">@food.OccurrenceCount</td>
                                    <td class="px-4 py-3">@food.TotalCalories.ToString("N0")</td>
                                    <td class="px-4 py-3">@food.TotalCarbs.ToString("N0")g</td>
                                    <td class="px-4 py-3">@food.TotalProtein.ToString("N0")g</td>
                                    <td class="px-4 py-3">@food.TotalFat.ToString("N0")g</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>

</section>

@code {
    private SummaryReportResponse? SummaryCards { get; set; }
    private FoodFrequencyReportResponse? FrequencyReport { get; set; }
    private List<AvailableFoodResponse> AvailableFoods { get; set; } = [];
    private ReportPeriod SelectedPeriod { get; set; } = ReportPeriod.Month;
    private Guid? SelectedFoodId { get; set; }
    private DateTime? CustomStartDate { get; set; }
    private DateTime? CustomEndDate { get; set; }

    private string DisplayReportDateRange => FrequencyReport?.Period switch
    {
        ReportPeriod.AllTime => "All Time",
        _ => $"{FrequencyReport?.ReportStartDate:MMM dd, yyyy} - {FrequencyReport?.ReportEndDate:MMM dd, yyyy}"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadSummaryCardsAsync();
        await LoadAvailableFoodsAsync();
    }

    private async Task LoadSummaryCardsAsync()
    {
        var userId = CurrentUserService.Id;
        if (string.IsNullOrWhiteSpace(userId)) return;

        SummaryCards = await ReportService.GetSummaryReportAsync(userId, CancellationToken.None);
    }

    private async Task LoadAvailableFoodsAsync()
    {
        var userId = CurrentUserService.Id;
        if (string.IsNullOrWhiteSpace(userId)) return;

        AvailableFoods = await ReportService.GetAvailableFoodsAsync(userId, CancellationToken.None);
    }

    private async Task GenerateReportAsync()
    {
        var userId = CurrentUserService.Id;
        if (string.IsNullOrWhiteSpace(userId)) return;

        var request = new FoodFrequencyRequest(SelectedFoodId, CustomStartDate, CustomEndDate, SelectedPeriod);

        FrequencyReport = await ReportService.GetFoodFrequencyReportAsync(userId, request, CancellationToken.None);
    }

    private async Task ClearFilters()
    {
        SelectedPeriod = ReportPeriod.Month;
        SelectedFoodId = null;
        CustomStartDate = null;
        CustomEndDate = null;
    }
}
