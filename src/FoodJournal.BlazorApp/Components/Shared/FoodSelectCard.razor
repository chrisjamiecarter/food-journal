@using FoodJournal.Application.Entities

<div class="@GetClasses()" @onclick="OnClick">
    <div class="relative">
        <div class="flex items-center justify-center">
            <img src="@Food.Base64Image" alt="@Food.Name" class="w-12 h-12 object-cover rounded" />
            @if (IsSelected)
            {
                <div class="absolute -top-1 -right-1 bg-cyan-400 rounded-full w-4 h-4 flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                </div>
            }
        </div>
    </div>
    <div class="mt-1 text-center">
        <div class="text-xs font-medium text-gray-700 text-center block truncate max-w-[80px]">
            @Food.Name
        </div>
        <div class="text-xs font-semibold text-emerald-600">
            @Food.Calories kcal
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Food Food { get; set; } = null!;

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetClasses() =>
        $"cursor-pointer transition-all duration-200 hover:scale-105 p-2 rounded-lg " +
        (IsSelected ? "bg-cyan-100 ring-2 ring-cyan-400" : "bg-white");
}
