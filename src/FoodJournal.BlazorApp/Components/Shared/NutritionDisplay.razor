@using FoodJournal.Application.Entities

<div class="flex flex-col items-end">
    <div class="font-semibold text-emerald-400 text-sm">@Food.Calories kcal</div>
    <div class="flex gap-2 text-xs">
        <span class="text-amber-400">Carbs: @Food.Carbs g</span>
        <span class="text-cyan-400">Protein: @Food.Protein g</span>
        <span class="text-rose-400">Fat: @Food.Fat g</span>
    </div>
</div>

@code {
    [Parameter]
    public Food Food { get; set; } = null!;
}
